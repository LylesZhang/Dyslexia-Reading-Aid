{
  "manifest_version": 3,
  "name": "Dyslexia Reading Aid",
  "version": "0.1.0",
  "description": "AI-powered reading aid for people with dyslexia. Customizes any webpage with visual aids for better reading experience.",

  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "sidePanel",
    "tabs"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background/index.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/index.js"],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    }
  ],

  "side_panel": {
    "default_path": "panel/panel.html"
  },

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Deja Reading Aid"
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
